# Supabase — required
# Get these from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for the integration test layer
# Create a dedicated Supabase test project and put its keys here
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=
TEST_SUPABASE_USER_EMAIL=
TEST_SUPABASE_USER_PASSWORD=

# CLI source — only set if developing/forking the modules repo
# Defaults to the public Stax mono-repo if unset
STAX_MODULES_REPO=Beautiful-Possibilities/stax-modules
STAX_MODULES_BRANCH=main
